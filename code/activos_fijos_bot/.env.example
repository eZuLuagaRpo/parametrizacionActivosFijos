# Copiar este archivo como ".env" (sin .example) y completar los valores
# reales en el PC de la empresa. NUNCA subir el .env real a git.
#
# Ver GUIA_MODIFICACION.md, sección "Dónde y cómo crear/editar variables
# de configuración", para el detalle de qué va aquí vs. en settings.py
# vs. en asset_type_mapping.py.

# -------------------------------------------------
# APPIAN
# -------------------------------------------------
APPIAN_URL=https://appian.bancolombia.com.co/suite
APPIAN_USER=xx@bancolombia.com.co
APPIAN_PASSWORD=
APPIAN_BROWSER=edge
APPIAN_TIMEOUT=90
APPIAN_TIMEOUT_FILES=600

# TODO-PENDIENTE-ACCESO-REAL: solo si se termina usando download_report
# como mecanismo complementario de descubrimiento de casos.
APPIAN_REPORT_FLOW_NAME=
APPIAN_REPORT_NAME=

# Carpeta donde appian-flow deja los Excels descargados de cada solicitud.
DOWNLOAD_DIR=C:/activos_fijos_bot/downloads

# Carpeta donde se dejan los Excels ya transformados al formato Z_AM_MASIVA.
OUTPUT_DIR=C:/activos_fijos_bot/output

# -------------------------------------------------
# SAP (Fase 3 — se completa cuando haya acceso real)
# -------------------------------------------------
# TODO-PENDIENTE-ACCESO-REAL: confirmar URL/login real de SAP Web y si
# difiere entre CP1 (pruebas) y EP1 (productivo).
SAP_ENVIRONMENT=CP1
SAP_URL=
SAP_USER=
SAP_PASSWORD=
SAP_BROWSER=edge
SAP_TIMEOUT=90

# IMPORTANTE: dejar en True hasta validar manualmente que el bot funciona
# bien. Solo pasar a False cuando se quiera ejecutar en modo real
# (desmarca "Ejecución de test" en Z_AM_MASIVA). Ver checklist de
# traslado en GUIA_MODIFICACION.md.
SAP_MODO_PRUEBA=True

# -------------------------------------------------
# GENERAL
# -------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=C:/activos_fijos_bot/logs
POLL_INTERVAL_SECONDS=300
